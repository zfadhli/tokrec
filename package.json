{
  "name": "@zfadhli/tokrec",
  "version": "0.10.0",
  "description": "Minimal TikTok live stream recorder — Bun + TypeScript",
  "type": "module",
  "main": "./dist/lib.mjs",
  "types": "./dist/lib.d.mts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.mts",
      "default": "./dist/lib.mjs"
    },
    "./cli": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "bin": {
    "tokrec": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/"
  },
  "dependencies": {
    "@zfadhli/koko-cli": "^0.1.0",
    "peaknorm": "^0.5.1",
    "wreq-js": "^2.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/bun": "latest",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.2"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zfadhli/tokrec.git"
  },
  "bugs": {
    "url": "https://github.com/zfadhli/tokrec/issues"
  },
  "homepage": "https://github.com/zfadhli/tokrec",
  "publishConfig": {
    "access": "public"
  }
}

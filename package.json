{
  "name": "tiktok-live-recorder-bun",
  "version": "0.1.0",
  "description": "Minimal TikTok live stream recorder — Bun + TypeScript",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tiktok-live-recorder": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/"
  },
  "dependencies": {
    "wreq-js": "^2.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9",
    "@types/bun": "latest",
    "tsdown": "^0.22",
    "typescript": "^5.8"
  },
  "engines": {
    "bun": ">=1.2"
  },
  "license": "MIT"
}

{
  "name": "@zfadhli/tokrec",
  "version": "0.2.1",
  "description": "Minimal TikTok live stream recorder — Bun + TypeScript",
  "type": "module",
  "main": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "default": "./dist/lib.js"
    },
    "./cli": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "tiktok-live-recorder": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/"
  },
  "dependencies": {
    "@zfadhli/koko-cli": "^0.1.0",
    "wreq-js": "^2.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9",
    "@types/bun": "latest",
    "tsdown": "^0.22",
    "typescript": "^5.8"
  },
  "engines": {
    "bun": ">=1.2"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}

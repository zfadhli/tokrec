{
  "compilerOptions": {
    // --- Language & Environment ---
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],

    // --- Type Checking ---
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    // --- Module Resolution ---
    "types": ["bun-types"],
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "esModuleInterop": true,

    // --- Declaration Output (used by tsdown, not tsc) ---
    "isolatedDeclarations": true,
    "declaration": true,
    "declarationMap": true,

    // --- Build Output (tsdown controls this; tsc --noEmit) ---
    "noEmit": true,
    "outDir": "dist",
    "declarationDir": "dist",
    "sourceMap": true
  },
  "include": ["src", "test"],
  "exclude": ["dist", "node_modules"]
}
